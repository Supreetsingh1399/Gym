{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "allowJs": true,
    "outDir": "build",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["node", "nativewind/types"],
    "jsx": "react-native",
    "esModuleInterop": true,
    "lib": ["es6", "ES2015", "DOM"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"],
  "extends": "expo/tsconfig.base"
}
