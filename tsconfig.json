{
  "compilerOptions": {
    "types": [
      "nativewind/types"
    ],
    "jsx": "react-native",
    "esModuleInterop": true,
    "lib": [
      "ES2015",
      "DOM"
    ],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "*": [
        "*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
